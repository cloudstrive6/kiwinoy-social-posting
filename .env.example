# ==========================================================================
#  KiwinoyGamer Social Posting — SECRETS
#  Copy this file to ".env" and paste your real keys. NEVER commit ".env".
# ==========================================================================

# Anthropic (Claude) — optional: only if you set writer_provider: anthropic
# for the FB/IG captions. Get it at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-paste-your-claude-key-here

# Claude Code OAuth token — powers the dedicated Threads track on your Claude
# subscription (no per-token billing). Generate with:  claude setup-token
# (requires a Claude Pro/Max subscription). Valid ~1 year.
CLAUDE_CODE_OAUTH_TOKEN=paste-your-claude-code-oauth-token-here

# OpenAI — used for trend research (web search) and image generation.
# Get it at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-openai-key-here

# Post for Me — uploads images and schedules posts to FB / IG / Threads.
# Get it at https://www.postforme.dev/  (Dashboard -> API Keys)
POSTFORME_API_KEY=paste-your-post-for-me-key-here

# ElevenLabs — OPTIONAL. AI Taglish voiceover narration on reels. Without it,
# reels render music-only (no error). Get it at https://elevenlabs.io/
# (Profile -> API Keys). Pick a young, Taglish-capable voice and put its id in
# config.yaml -> reels.narration.voice_id.
ELEVENLABS_API_KEY=paste-your-elevenlabs-key-here
