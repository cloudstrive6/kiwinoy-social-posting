# ==========================================================================
#  KiwinoyGamer Social Posting — SECRETS
#  Copy this file to ".env" and paste your real keys. NEVER commit ".env".
# ==========================================================================

# Anthropic (Claude) — writes the captions and Threads posts.
# Get it at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-paste-your-claude-key-here

# OpenAI — used for trend research (web search) and image generation.
# Get it at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-openai-key-here

# Post for Me — uploads images and schedules posts to FB / IG / Threads.
# Get it at https://www.postforme.dev/  (Dashboard -> API Keys)
POSTFORME_API_KEY=paste-your-post-for-me-key-here
