# Secrets — never commit
.env

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# Generated output (images, run logs, briefs)
output/
*.log

# Node / Remotion
node_modules/
reels/out/
# Local music library is large — only a curated set is force-added for CI
reels/assets/music/*.mp3
reels/assets/music/*.m4a
reels/assets/music/*.wav
reels/assets/music/*.ogg
# Per-run reel assets copied into public at render time (keep the folder)
reels/public/*
!reels/public/.gitkeep
# Footage: ignore ALL clips by default so a huge accidental paste (e.g. a 40GB
# raw recording) can never be staged/committed and break a push. Small clips that
# SHOULD ship in the repo are force-added with `git add -f <file>`; big clips go
# on the 'footage' GitHub Release via tools/footage.py. Already-committed small
# clips stay tracked (gitignore does not untrack).
reels/assets/footage/*/*.mp4
reels/assets/footage/*/*.mov
reels/assets/footage/*/*.webm
reels/assets/footage/*/*.m4v
reels/assets/footage/*/*.mkv
# Render-time download cache for release clips:
reels/assets/footage/.cache/

# Your finished reels drop-folder: big files, queued to the 'ready-reels' Release
# by tools/ready_reels.py (never committed to the repo).
reels/assets/ready/

# The big source animated logo (.mov, ~1GB ProRes) is not committed - it's split
# into the small kiwinoy_logo_rgb.mp4 + kiwinoy_logo_alpha.mp4 matte (tracked).
reels/assets/logo/*.mov
reels/assets/logo/*.mkv
reels/assets/logo/*.webm

# Reference-only sample reels the user drops in to show a target format (big,
# never committed — they're inspiration, not pipeline assets).
reels/assets/sample-reels-format-games/

# OS
.DS_Store
Thumbs.db

# Local Claude Code settings (machine-specific)
.claude/

# Long-form 4K HDR source parts (huge, local-only inputs)
reels/assets/longform/*
!reels/assets/longform/.gitkeep

# 4K/60 HDR YouTube Shorts footage pool (large, local-only; nvenc runs locally)
reels/assets/footage-4k/*
!reels/assets/footage-4k/.gitkeep

# Unified 4K/60 HDR source intake (huge raw captures; auto-archived to B2, then freed).
# Ignore the pasted media + pin markers; keep the README + .gitkeep skeleton in git.
reels/assets/4k-hdr/**/*.mp4
reels/assets/4k-hdr/**/*.mov
reels/assets/4k-hdr/**/*.mkv
reels/assets/4k-hdr/**/*.m4v
reels/assets/4k-hdr/**/*.avi
reels/assets/4k-hdr/**/*.ts
reels/assets/4k-hdr/**/.keep

# Generated YouTube thumbnail variants (per upload)
thumbnails/

# local one-off longform batch runners (hardcoded paths)
/process_ff7_fullgame.py
/run_ff7_fullgame.bat
