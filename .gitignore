# Secrets — never commit
.env

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# Generated output (images, run logs, briefs)
output/
*.log

# Node / Remotion
node_modules/
reels/out/
# Local music library is large — only a curated set is force-added for CI
reels/assets/music/*.mp3
reels/assets/music/*.m4a
reels/assets/music/*.wav
reels/assets/music/*.ogg
# Per-run reel assets copied into public at render time (keep the folder)
reels/public/*
!reels/public/.gitkeep
# Footage clips committed to the repo must stay under GitHub's 100MB/file limit.
# Bigger clips go on the 'footage' GitHub Release instead (tools/footage.py).
# Render-time download cache for those release clips:
reels/assets/footage/.cache/
# This oversized local clip is excluded (it's on the Release instead):
reels/assets/footage/**/Hero Spotlight*Hirara*.mp4

# OS
.DS_Store
Thumbs.db

# Local Claude Code settings (machine-specific)
.claude/
